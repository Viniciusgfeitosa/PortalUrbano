@{
    Layout = null;
    var moderacao = Context.Request.Query["moderacao"].ToString();
    var avisos = 0;
    int.TryParse(Context.Request.Query["avisos"].ToString(), out avisos);
    var usuarioBanido = moderacao == "banido";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Criar Denúncia - Portal Urbano</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #f97316;
            --primary-hover: #ea580c;
            --bg-dark: #020617;
            --bg-panel: rgba(15, 23, 42, 0.9);
            --text-light: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: rgba(255, 255, 255, 0.1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* HEADER */
        .header {
            text-align: center;
            padding: 40px 20px;
            background: linear-gradient(180deg, rgba(15, 23, 42, 1) 0%, rgba(2, 6, 23, 0) 100%);
            border-bottom: 1px solid var(--border-color);
        }

        .header h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: var(--text-muted);
            font-size: 16px;
        }

        /* NAV BACK */
        .nav-back {
            position: absolute;
            top: 45px;
            left: 40px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }
        .nav-back:hover {
            color: var(--primary);
        }

        /* MAIN CONTAINER */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            flex: 1;
        }

        /* LEFT SIDE (Placeholder) */
        .left-col {
            display: flex;
            flex-direction: column;
        }

        .left-col h2 {
            font-size: 24px;
            margin-bottom: 8px;
            color: var(--text-light);
        }

        .left-col p {
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .image-placeholder {
            flex: 1;
            min-height: 400px;
            background: var(--bg-panel);
            border: 1px dashed rgba(255,255,255,0.2);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
        }
        .image-placeholder:hover {
            border-color: var(--primary);
            background: rgba(15, 23, 42, 0.95);
        }

        /* RIGHT SIDE (Form) */
        .right-col {
            background: var(--bg-panel);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            padding: 32px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .alert {
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
            line-height: 1.45;
            font-weight: 500;
        }

        .alert-warning {
            background: rgba(249, 115, 22, 0.12);
            border: 1px solid rgba(249, 115, 22, 0.35);
            color: #fed7aa;
        }

        .alert-danger {
            background: rgba(239, 68, 68, 0.12);
            border: 1px solid rgba(239, 68, 68, 0.35);
            color: #fecaca;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .glass-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-color);
            color: var(--text-light);
            padding: 14px 16px;
            border-radius: 12px;
            font-size: 15px;
            transition: all 0.3s ease;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .glass-input:focus {
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.2);
        }

        .glass-input::placeholder {
            color: #64748b;
        }

        .glass-input option {
            background: #0f172a;
            color: white;
        }

        textarea.glass-input {
            resize: vertical;
            min-height: 100px;
        }

        /* TOGGLE SWITCH */
        .toggle-group {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px;
            padding: 10px 0;
        }

        .toggle-label {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-light);
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 28px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(255, 255, 255, 0.1);
            transition: .4s;
            border-radius: 34px;
            border: 1px solid var(--border-color);
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: var(--text-muted);
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: var(--primary);
            border-color: var(--primary);
        }

        input:checked + .slider:before {
            transform: translateX(22px);
            background-color: white;
        }

        /* SUBMIT BUTTON */
        .btn-submit {
            background: linear-gradient(135deg, var(--primary) 0%, #c2410c 100%);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            width: 100%;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(249, 115, 22, 0.3);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(249, 115, 22, 0.4);
        }

        .btn-submit:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* MEDIA QUERIES */
        @@media (max-width: 992px) {
            .container {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .nav-back {
                position: relative;
                top: 0;
                left: 0;
                justify-content: center;
                margin-bottom: 20px;
            }
            .image-placeholder {
                min-height: 250px;
            }
        }
    </style>
</head>
<body>

    <div class="header">
        <a href="javascript:history.back()" class="nav-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Voltar
        </a>
        <h1>Criar Denúncia</h1>
        <p>Preencha as informações abaixo para relatar um incidente no portal.</p>
    </div>

    <div class="container">
        <!-- LEFT COLUMN -->
        <div class="left-col">
            <h2>Formulário de Denúncia</h2>
            <p>Adicione detalhes sobre a ocorrência para ajudar na identificação.</p>
            
            <div class="image-placeholder">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="right-col">
            @if (usuarioBanido)
            {
                <div class="alert alert-danger">
                    Seu usuario foi banido do sistema apos 3 avisos. Voce nao pode criar novas denuncias.
                </div>
            }
            else if (moderacao == "aviso")
            {
                <div class="alert alert-warning">
                    Denuncia bloqueada: o titulo ou a descricao violam as regras de moderacao (analise automatica). Aviso @avisos de 3.
                </div>
            }

            <form action="/api/Denuncia" method="post" enctype="multipart/form-data">
                <!-- Campos Ocultos para Latitude e Longitude (usando nomes diferentes para evitar conflito de binding) -->
                <input type="hidden" id="latitude" name="lat_str" value="0" />
                <input type="hidden" id="longitude" name="lon_str" value="0" />

                <div class="input-group">
                    <label for="titulo">Título</label>
                    <input type="text" id="titulo" name="titulo" class="glass-input" placeholder="Insira o título da denúncia" required />
                </div>

                <div class="input-group">
                    <label for="descricao">Descrição</label>
                    <textarea id="descricao" name="descricao" class="glass-input" placeholder="Insira uma descrição detalhada da ocorrência (opcional)"></textarea>
                </div>

                <div class="input-group">
                    <label for="categoria">Categoria</label>
                    <select id="categoria" name="idCategoria" class="glass-input" required>
                        <option value="" disabled selected>Carregando categorias...</option>
                    </select>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 15px;">
                    <div class="input-group">
                        <label for="cep">CEP</label>
                        <input type="text" id="cep" name="cep" class="glass-input" placeholder="00000-000" />
                    </div>
                    <div class="input-group">
                        <label for="rua">Rua</label>
                        <input type="text" id="rua" name="rua" class="glass-input" placeholder="Nome da rua" required />
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="input-group">
                        <label for="bairro">Bairro</label>
                        <input type="text" id="bairro" name="bairro" class="glass-input" placeholder="Bairro" required />
                    </div>
                    <div class="input-group">
                        <label for="cidade">Cidade</label>
                        <input type="text" id="cidade" name="cidade" class="glass-input" placeholder="Cidade" required />
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 100px 1fr; gap: 15px;">
                    <div class="input-group">
                        <label for="uf">UF</label>
                        <input type="text" id="uf" name="uf" class="glass-input" placeholder="SP" required />
                    </div>
                    <div class="input-group">
                        <label for="complemento">Ponto de Referência / Complemento</label>
                        <input type="text" id="complemento" name="complemento" class="glass-input" placeholder="Ex: Próximo à padaria" />
                    </div>
                </div>

                <div class="input-group">
                    <label for="imagens">Adicionar Imagens</label>
                    <input type="file" id="imagens" name="imagens" class="glass-input" accept="image/*" multiple style="padding: 10px 16px;" />
                </div>

                <div class="toggle-group">
                    <span class="toggle-label">Postar Anônimo?</span>
                    <label class="switch">
                        <input type="checkbox" id="anonimo" name="anonimo">
                        <span class="slider"></span>
                    </label>
                </div>

                <button type="submit" class="btn-submit" @(usuarioBanido ? "disabled" : "")>
                    Enviar Denúncia
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </form>
        </div>
    </div>

    <script>
        // Preview da imagem
        document.getElementById('imagens').addEventListener('change', function(e) {
            const placeholder = document.querySelector('.image-placeholder');
            const files = e.target.files;

            if (files && files.length > 0) {
                const file = files[0];
                const reader = new FileReader();

                reader.onload = function(event) {
                    placeholder.innerHTML = `<img src="${event.target.result}" alt="Preview" style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 16px;" />`;
                }
                reader.readAsDataURL(file);
            } else {
                placeholder.innerHTML = `
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>`;
            }
        });

        // Carregar categorias do banco
        async function loadCategories() {
            try {
                const res = await fetch('/api/Denuncia/categorias');
                const categories = await res.json();
                const select = document.getElementById('categoria');
                select.innerHTML = '<option value="" disabled selected>Selecione uma categoria</option>';
                
                categories.forEach(cat => {
                    const opt = document.createElement('option');
                    opt.value = cat.idCategoria;
                    opt.innerText = cat.nome;
                    select.appendChild(opt);
                });
            } catch (e) { console.error("Erro ao carregar categorias:", e); }
        }
        loadCategories();

        // ViaCEP e Geocodificação (Nominatim)
        document.getElementById('cep').addEventListener('blur', async function() {
            let cep = this.value.replace(/\D/g, '');
            const submitBtn = document.querySelector('button[type="submit"]');
            const cepInput = this;

            if (cep.length === 8) {
                try {
                    console.log("Buscando CEP:", cep);
                    cepInput.style.borderColor = "var(--primary)";
                    if (submitBtn) submitBtn.disabled = true;
                    if (submitBtn) submitBtn.innerText = "Buscando localização...";

                    // Busca endereço pelo ViaCEP
                    const response = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
                    const data = await response.json();
                    
                    if (!data.erro) {
                        document.getElementById('rua').value = data.logradouro || '';
                        document.getElementById('bairro').value = data.bairro || '';
                        document.getElementById('cidade').value = data.localidade || '';
                        document.getElementById('uf').value = data.uf || '';
                        
                        // Busca Latitude e Longitude usando Nominatim (OpenStreetMap)
                        const addressQuery = `${data.logradouro}, ${data.bairro}, ${data.localidade}, ${data.uf}, Brazil`;
                        console.log("Buscando coordenadas para:", addressQuery);
                        
                        const geoResponse = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(addressQuery)}`);
                        const geoData = await geoResponse.json();

                        if (geoData && geoData.length > 0) {
                            const lat = geoData[0].lat;
                            const lon = geoData[0].lon;
                            console.log("Coordenadas encontradas:", lat, lon);
                            
                            document.getElementById('latitude').value = lat;
                            document.getElementById('longitude').value = lon;
                            cepInput.style.borderColor = "#22c55e"; // Verde sucesso
                        } else {
                            console.warn("Geocodificação não encontrou as coordenadas.");
                            cepInput.style.borderColor = "#ef4444"; // Vermelho erro
                        }
                    } else {
                        cepInput.style.borderColor = "#ef4444";
                    }
                } catch (error) {
                    console.error("Erro ao buscar CEP ou Coordenadas:", error);
                    cepInput.style.borderColor = "#ef4444";
                } finally {
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.innerText = "Enviar Denúncia";
                    }
                }
            }
        });
    </script>
</body>
</html>
