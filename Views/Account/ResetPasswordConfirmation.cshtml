@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Senha redefinida - Portal Urbano</title>
    <style>
        :root{--bg:#071027;--panel:#061425;--accent:#f97316;--muted:#94a3b8}
        *{box-sizing:border-box}
        body,html{height:100%;margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,'Helvetica Neue',Arial;background:var(--bg)}
        .page{display:flex;height:100vh;min-height:100vh}
        .right{width:100%;background:var(--bg);display:flex;align-items:center;justify-content:center;padding:48px}
        .card{width:100%;max-width:460px;background:var(--panel);padding:32px;border-radius:12px;box-shadow:none;display:flex;flex-direction:column;gap:12px;text-align:center}
        .title{color:var(--accent);font-size:28px;font-weight:800;margin-bottom:6px}
        .desc{color:var(--muted)}
    </style>
</head>
<body>
    <div class="page">
        <div class="right">
            <div class="card">
                <div class="title">Senha redefinida</div>
                <div class="desc">Sua senha foi atualizada com sucesso. Faça login usando sua nova senha.</div>
                <div style="margin-top:18px"><a href="@Url.Action("Login","Account")">Voltar ao login</a></div>
            </div>
        </div>
    </div>
</body>
</html>