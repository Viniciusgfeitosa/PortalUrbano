@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Recuperar Senha - Portal Urbano</title>
    <style>
        :root{--bg:#071027;--panel:#061425;--accent:#f97316;--muted:#94a3b8}
        *{box-sizing:border-box}
        body,html{height:100%;margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,'Helvetica Neue',Arial;background:var(--bg)}
        .page{display:flex;height:100vh;min-height:100vh}
        .left{flex:0 0 50%;width:50%;background:url('/images/banner.png') center center/cover no-repeat;position:relative;display:flex;align-items:flex-start;justify-content:flex-start;min-height:100vh}
        .left::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg, rgba(2,6,23,0.3), rgba(2,6,23,0.6));z-index:1}
        .right{flex:0 0 50%;width:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;padding:48px}
        .card{width:100%;max-width:460px;background:var(--panel);padding:32px;border-radius:12px;box-shadow:none;display:flex;flex-direction:column;gap:12px}
        .title{color:var(--accent);font-size:28px;font-weight:800;margin-bottom:6px}
        label{display:block;color:var(--muted);font-size:13px;margin-bottom:8px}
        .input{width:100%;padding:12px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:#fff;margin-bottom:14px;height:48px;font-size:15px}
        .actions{display:flex;flex-direction:column;gap:12px;margin-top:12px}
        .btn-primary{background:var(--accent);color:#071027;border:none;padding:12px;border-radius:10px;font-weight:800;cursor:pointer;font-size:15px}
        .footer-links{text-align:center;margin-top:18px;color:var(--muted);font-size:14px}

        @@media(max-width:900px){.left{display:none!important}.page{flex-direction:column}.right{width:100%;padding:24px;height:100vh;display:flex;align-items:center;justify-content:center}.card{max-width:100%;padding:20px}}
    </style>
</head>
<body>
    <div class="page">
        <div class="left"><div class="brand"><!-- banner --></div></div>
        <div class="right">
            <div class="card">
                <div class="title">Recupere sua senha</div>

                <p style="color:var(--muted);margin:0 0 8px 0">Informe o email associado à sua conta. Enviaremos um link para redefinir sua senha.</p>

                <form method="post" asp-action="ForgotPassword">
                    @Html.AntiForgeryToken()
                    <div>
                        <label for="email">Email</label>
                        <input id="email" name="email" type="email" class="input" placeholder="usuario@gmail.com" required />
                    </div>

                    <div class="actions">
                        <button type="submit" class="btn-primary">Enviar link de recuperação</button>
                    </div>

                    <div class="footer-links"><a href="@Url.Action("Login","Account")">Voltar ao login</a></div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>